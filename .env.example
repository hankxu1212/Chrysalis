# Environment for the **integration test suite** in crates/crys-core/tests/.
# The `crys` CLI itself doesn't need any of this — use `crys config set
# --global default_profile <p>` and `... default_region <r>` instead.
#
# Copy to .env.local (gitignored) and source it before running tests:
#   set -a && . .env.local && set +a
#   cargo test --workspace

# --- Required ---

# Bucket the integration tests will write to. Tests isolate themselves under
# `crys-test/<pid>-<nanos>-<salt>/` keys and clean up after themselves.
# Leave unset to skip the integration tests entirely.
CRYS_TEST_BUCKET=your-test-bucket-name

# --- Only needed if your default AWS profile isn't the one you want tests
#     to use. The integration tests call S3Client::from_env(), which honors
#     the standard AWS credential chain. ---

# AWS_PROFILE=chrysalis-dev
# AWS_REGION=us-west-2

# --- Optional ---

# Verbose tracing from the SDK + crys-core. Examples:
#   RUST_LOG=crys_core=debug
#   RUST_LOG=aws_sdk_s3=debug,crys_core=debug
# RUST_LOG=warn
