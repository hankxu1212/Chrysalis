# Copy to .env and fill in your values. .env is gitignored.
#
# Source it before running tests:
#   set -a && . .env && set +a
#   cargo test --workspace
#
# Or run a single command with these vars:
#   env $(grep -v '^#' .env | xargs) cargo test -p crys-core --test s3_integration

# --- Required for the S3 integration tests in crates/crys-core/tests/ ---

# Bucket the integration tests will write to. Tests isolate themselves under
# `crys-test/<pid>-<nanos>-<salt>/` keys and clean up after themselves.
# Leave unset to skip the integration tests entirely.
CRYS_TEST_BUCKET=your-test-bucket-name

# --- AWS credentials (one of the options below) ---

# Option A: named profile from ~/.aws/credentials.
# AWS_PROFILE=default

# Option B: explicit static credentials. Prefer Option A in real use.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # only if using temporary credentials

# Region for the test bucket (also used to resolve the SDK endpoint).
AWS_REGION=us-east-1

# --- Optional ---

# Verbose tracing from the SDK + crys-core. Examples:
#   RUST_LOG=crys_core=debug
#   RUST_LOG=aws_sdk_s3=debug,crys_core=debug
# RUST_LOG=warn
